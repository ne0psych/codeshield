# CodeShield Environment Configuration
# Copy to .env and fill in your API keys

# NVD API key (optional, increases rate limit from 5 to 50 req/30s)
# Get one at: https://nvd.nist.gov/developers/request-an-api-key
CODESHIELD_NVD_API_KEY=

# GitHub token for Advisory Database sync (optional)
# Needs: read:packages scope
GITHUB_TOKEN=

# Database path (default: ./codeshield_data/codeshield.db)
# CODESHIELD_DB_PATH=./codeshield_data/codeshield.db

# Server configuration
# CODESHIELD_SERVER_HOST=127.0.0.1
# CODESHIELD_SERVER_PORT=5000

# Logging level (DEBUG, INFO, WARNING, ERROR)
# CODESHIELD_LOG_LEVEL=INFO

# Disable data sync at startup (useful for offline/dev)
# CODESHIELD_SYNC_ENABLED=false
